# Google Sheets API — 報價系統資料庫
# 1. 建立 Google Cloud 專案 → 啟用 Google Sheets API
# 2. 建立 Service Account → 下載 JSON 金鑰
# 3. 將 Service Account email 加入試算表「編輯者」權限
# 4. 將整份 JSON 金鑰內容貼到 GOOGLE_SERVICE_ACCOUNT_KEY

GOOGLE_SHEETS_SPREADSHEET_ID=你的試算表ID
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
GEMINI_API_KEY=your-gemini-api-key

# Giveme 電子發票 API
GIVEME_BASE_URL=https://www.giveme.com.tw/invoice.do
GIVEME_UNCODE=你的統一編號
GIVEME_IDNO=你的API帳號
GIVEME_PASSWORD=你的API密碼
